{
  "environment": "test",
  "debug": true,
  "api": {
    "base_url": "http://localhost:8000",
    "timeout": 5000,
    "retry_attempts": 1
  },
  "analytics": {
    "enabled": false,
    "provider": "none"
  },
  "logging": {
    "level": "error",
    "file": "logs/test.log"
  },
